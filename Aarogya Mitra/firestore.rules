rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow staff to manage users
    match /users/{userId} {
      allow read, write: if request.auth != null || true; // Opened for demo
    }

    // Allow patients to book and trigger SOS, staff to manage
    match /queue/{id} {
      allow read, write: if true;
    }

    match /notifications/{id} {
      allow read, write: if true;
    }
    
    match /appointments/{id} {
      allow read, write: if true;
    }

    match /beds/{id} {
      allow read: if true;
      allow write: if request.auth != null || true; // Opened for demo
    }
  }
}